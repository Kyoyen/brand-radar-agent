# ============================================================
# Marketing Agent OS — 环境变量配置
# 使用方法：复制本文件为 .env，填入真实值
#   cp .env.example .env
# ============================================================

# ── 大模型配置（必填其中一组）──────────────────────────────────

# 选项 1：OpenAI（默认，推荐新手使用）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# 选项 2：Anthropic Claude（注释掉选项1，取消注释这里）
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# 选项 3：DeepSeek（国内可访问，价格低）
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=sk-...

# 选项 4：月之暗面 Moonshot（国内）
# LLM_PROVIDER=moonshot
# LLM_MODEL=moonshot-v1-8k
# MOONSHOT_API_KEY=...

# 选项 5：智谱 GLM（国内，有免费额度）
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
# ZHIPU_API_KEY=...

# ── 业务配置（必填）────────────────────────────────────────────

# 我方品牌名（分析报告中的"我方"指的是这个品牌）
TARGET_BRAND=肯德基

# 默认竞品列表（逗号分隔，Agent 运行时可动态覆盖）
COMPETITOR_BRANDS=麦当劳,汉堡王,华莱士

# 默认监控平台（逗号分隔）
MONITOR_PLATFORMS=小红书,抖音,微博

# ── 推送配置（可选）────────────────────────────────────────────

# 飞书群机器人 Webhook（不填则只在终端打印报告，不推送）
# 获取方式：飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=

# ── 高级配置（可选，一般不需要改）────────────────────────────────

# 每次 Agent 执行最多几轮推理（防止死循环）
AGENT_MAX_TURNS=12

# 每几次工具调用触发一次上下文压缩
AGENT_CHECKPOINT_EVERY=5

# 调试模式（true = 打印详细日志）
DEBUG=false
