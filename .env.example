# ============================================================
# Brand Radar Agent — 环境变量配置
# 用法：cp .env.example .env  然后填入真实值
# 注意：完全不填也能运行（自动启用 MockProvider 演示模式）
# ============================================================

# ── LLM 配置 ────────────────────────────────────────────────────
# 默认：DeepSeek（国内首选，价格低，单次任务约 ¥0.001）

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# 切换其他平台：注释掉上面 3 行，取消下方对应组的注释

# OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=

# 月之暗面 Moonshot
# LLM_PROVIDER=moonshot
# LLM_MODEL=moonshot-v1-8k
# MOONSHOT_API_KEY=

# 智谱 GLM（有免费额度）
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-flash
# ZHIPU_API_KEY=

# ── 业务配置 ────────────────────────────────────────────────────

TARGET_BRAND=肯德基
COMPETITOR_BRANDS=麦当劳,汉堡王,华莱士
MONITOR_PLATFORMS=小红书,抖音,微博

# ── 推送配置（可选）─────────────────────────────────────────────
# 飞书机器人 Webhook（不填则报告只在终端打印）
# 获取：飞书群 → 设置 → 群机器人 → 添加自定义机器人

FEISHU_WEBHOOK_URL=

# ── 高级配置（一般不动）─────────────────────────────────────────

AGENT_MAX_TURNS=12
AGENT_CHECKPOINT_EVERY=5
DEBUG=false
